		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jest": "^30.3.0",
		"jiti": "2.6.1",
		"ts-jest": "^29.4.6",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"md-ast-core": "file:../md-ast-core/md-ast-core-1.0.0.tgz",
