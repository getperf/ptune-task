{
	"name": "obsidian-ptune-task",
	"version": "1.0.0",
	"description": "Ptune task plugin for daily planning and Google Tasks sync",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"codegen:xmind-template": "node scripts/generate-xmind-template.mjs",
		"dev": "node esbuild.config.mjs --watch",
		"build": "node esbuild.config.mjs",
		"prepare-dist": "node scripts/prepare-dist.mjs",
		"package": "npm run build && npm run prepare-dist && node scripts/make-zip.mjs",
		"predev": "npm run codegen:xmind-template",
		"prebuild": "npm run codegen:xmind-template",
		"prelint": "npm run codegen:xmind-template",
		"prelint:reviewbot": "npm run codegen:xmind-template",
		"pretest": "npm run codegen:xmind-template",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:reviewbot": "eslint \"src/**/*.ts\" --ignore-pattern \"src/**/*.test.ts\" --ignore-pattern \"src/**/__tests__/**\" --rule \"require-await:off\" --rule \"@typescript-eslint/require-await:error\"",
		"test": "jest"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jest": "^30.3.0",
		"jiti": "2.6.1",
		"ts-jest": "^29.4.6",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"md-ast-core": "^1.0.0",
		"obsidian": "latest",
		"obsidian-daily-notes-interface": "^0.9.4",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"unified": "^11.0.5",
		"unist-util-visit-parents": "^6.0.2"
	},
	"overrides": {
		"brace-expansion": "^2.0.3",
		"flatted": "^3.4.2",
		"handlebars": "^4.7.9",
		"minimatch": "^9.0.9",
		"picomatch": "^4.0.4"
	}
}
